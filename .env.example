# MetaTrader5 credentials
MT5_LOGIN=your_login
MT5_PASSWORD=your_password
MT5_SERVER=your_server

# VNC access password
VNC_PASSWORD=your_vnc_password

# API authentication (optional, if not set auth is disabled)
# API_KEY=your-secure-api-key

# CORS allowed origins
# ALLOWED_ORIGINS=http://localhost:8080

# Ports
VNC_PORT=3000
API_PORT=8000
MT5_PORT=8001

# Versions
MT5_VERSION=5.0.36
WINE_VERSION=win10

# Download URLs (optional, use only if defaults fail)
# MONO_URL=https://dl.winehq.org/wine/wine-mono/8.0.0/wine-mono-8.0.0-x86.msi
# PYTHON_URL=https://www.python.org/ftp/python/3.9.0/python-3.9.0.exe
# MT5_DOWNLOAD_URL=https://download.mql5.com/cdn/web/metaquotes.software.corp/mt5/mt5setup.exe

# Advanced configuration
DOWNLOAD_TIMEOUT=300
MAX_RETRIES=3
LOG_LEVEL=INFO
